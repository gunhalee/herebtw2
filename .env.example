# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=

# Browser/client key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only key. Never expose this in client code.
SUPABASE_SECRET_KEY=

# Public data.go.kr API key. Use only on the server.
DATA_GO_KR_SERVICE_KEY=
# DATA_GO_KR_SERVICE_KEY_IS_ENCODED=1
# DATA_GO_KR_SERVICE_KEY_PARAM=ServiceKey
# DATA_GO_KR_SERVICE_KEY_FIRST=1
# DATA_GO_KR_HTTP_REFERER=https://www.data.go.kr/
