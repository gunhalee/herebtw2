# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=

# Browser/client key: publishable (sb_publishable_…) or legacy JWT anon (either works).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Alternative name supported by some Supabase UI docs.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only key. Never expose this in client code.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 공공데이터포털(선거인수 API 등). 로컬에서만 사용 — 클라이언트 번들에 넣지 마세요.
DATA_GO_KR_SERVICE_KEY=
# HTTP 403 시: 마이페이지 → 활용신청 현황에서 해당 API「변경신청」 후 1~2시간 대기·허용 IP 확인
# HTTP 401 시: 포털의 Encoding(일반) 키를 쓰면 1
# DATA_GO_KR_SERVICE_KEY_IS_ENCODED=1
# 구형 예제와 같이 ServiceKey(대문자 S) 파라미터가 필요하면:
# DATA_GO_KR_SERVICE_KEY_PARAM=ServiceKey
# serviceKey 를 쿼리 맨 앞에 두어야 할 때: 1
# DATA_GO_KR_SERVICE_KEY_FIRST=1
# 일부 환경에서만: Referer (기본은 https://www.data.go.kr/)
# DATA_GO_KR_HTTP_REFERER=https://www.data.go.kr/
